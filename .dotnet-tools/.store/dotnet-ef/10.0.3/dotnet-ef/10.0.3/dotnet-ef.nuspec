    <tags>Entity Framework Core entity-framework-core EF Data O/RM EntityFramework EntityFrameworkCore EFCore</tags>
    <serviceable>true</serviceable>
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
    <repository type="git" url="https://github.com/dotnet/dotnet" commit="c2435c3e0f46de784341ac3ed62863ce77e117b4" />
  </metadata>
</package>